# Local dev: leave unset to use ./data/ (filesystem).
#
# Vercel production: create a private Blob store (Project → Storage → Blob,
# access: Private) and connect it to this project. Vercel injects
# BLOB_READ_WRITE_TOKEN automatically. Without it, uploads fail with EROFS
# (read-only filesystem on /var/task).
#
# BLOB_READ_WRITE_TOKEN=

# Moderation (optional): required for DELETE /api/photos/[id] and /api/auth/moderation.
# Generate a long random string for MODERATION_SECRET (16+ chars).
# MODERATION_SECRET=
# MODERATION_PASSWORD=

# Optional: canonical site URL for Open Graph / metadata (e.g. https://your-app.vercel.app)
# NEXT_PUBLIC_SITE_URL=
