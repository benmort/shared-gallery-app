# Local dev: leave unset to use ./data/ (filesystem).
#
# Vercel production: create a private Blob store (Project → Storage → Blob,
# access: Private) and connect it to this project. Vercel injects
# BLOB_READ_WRITE_TOKEN automatically. Without it, uploads fail with EROFS
# (read-only filesystem on /var/task).
#
# BLOB_READ_WRITE_TOKEN=

# Moderation (optional): required for ?moderation=true (bulk delete) and POST /api/auth/moderation.
# Copy this file to .env.local (gitignored), set both values, restart `pnpm dev`.
#
# MODERATION_SECRET — random string, at least 16 characters (signs the session cookie).
# MODERATION_PASSWORD — at least 8 characters (the password you type in the moderation UI).
#
# MODERATION_SECRET=change-me-to-a-long-random-string
# MODERATION_PASSWORD=change-me-to-a-strong-password
#
# Vercel: Project → Settings → Environment Variables → add both for Production (and Preview if needed) → Redeploy.

# Upload hardening toggles (optional)
# MOMENTS_UPLOAD_V2_ENABLED=true
# MOMENTS_UPLOAD_PARALLELISM=3
# MOMENTS_UPLOAD_RETRY_COUNT=3
# MOMENTS_UPLOAD_RATE_LIMIT=120
# MOMENTS_UPLOAD_RATE_WINDOW_MS=60000
# MOMENTS_UPLOAD_BEARER_TOKEN=
# MOMENTS_UPLOAD_REQUIRE_MODERATION=false
# CRON_SECRET=

# Optional: canonical site URL for Open Graph / metadata (e.g. https://your-app.vercel.app)
# NEXT_PUBLIC_SITE_URL=

# Summit data source:
# Summit routes now use singleton data from `lib/summit/data/data.json`.
# No summit-specific environment variables are required.
